# llm-sandbox 公式 python311.Dockerfile に準拠
# slim-bullseye: ~50MB vs ~350MB for full bullseye — much faster first pull
# Non-Python languages (JS/Go/Rust/Bash) use llm_sandbox defaults — no bloat here.
FROM python:3.11-slim-bullseye

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Install system dependencies: Python build tools only
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    python3-venv \
    git \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Python packages (llm-sandbox標準セット + データサイエンス)
RUN pip install --no-cache-dir \
    numpy pandas matplotlib pillow \
    seaborn scikit-learn scipy scikit-image plotly \
    requests httpx

# Create workspace with permissive permissions (container may run as non-root)
RUN mkdir -p /sandbox/uploads /sandbox/output && chmod 777 /sandbox
WORKDIR /sandbox

CMD ["tail", "-f", "/dev/null"]