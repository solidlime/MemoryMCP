# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment
venv*/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Runtime data
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*.log

# Local env
.env

# Model cache
.cache/

# Generated output
output/
logs/

# Data runtime (allow: .gitkeep, SKILL.md, seed settings)
data/*/
data/_tmp/
!data/*.zip
# searxng: allow only .gitkeep (settings.yml auto-generated on first docker-compose up)
!data/searxng/
data/searxng/*
!data/searxng/.gitkeep
# SearXNG — auto-generated on first docker-compose up
data/searxng/settings.yml
# skills: allow only SKILL.md + .gitkeep, exclude SQLite DBs
!data/skills/
data/skills/*
!data/skills/*/
!data/skills/**/SKILL.md
!data/skills/.gitkeep
# import: allow only .gitkeep
!data/import/
data/import/*
!data/import/done/
!data/import/.gitkeep
!data/import/done/.gitkeep
# config: allow only .gitkeep
!data/config/
data/config/*
!data/config/.gitkeep
# logs: allow only .gitkeep
!data/logs/
data/logs/*
!data/logs/.gitkeep
# backups: allow only .gitkeep
!data/backups/
data/backups/*
!data/backups/.gitkeep

# Serena local files
.serena/
tmp-screenshots/

# Node modules (plugins)
node_modules/
.opencode/

# Autogenerated files
coverage.json
CHANGELOG.md
