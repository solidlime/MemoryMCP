# Example .env file for development. Copy to .env and edit.
MEMORY_MCP_QDRANT_URL=http://localhost:6333
MEMORY_MCP_SERVER_PORT=26262
MEMORY_MCP_DATA_ROOT=./data
# Set keys for summarization / LLM integration only if you need them
# MEMORY_MCP_SUMMARIZATION_ENABLED=true
# MEMORY_MCP_SUMMARIZATION_USE_LLM=false
# MEMORY_MCP_SUMMARIZATION_LLM_API_URL=
# MEMORY_MCP_SUMMARIZATION_LLM_API_KEY=
# MEMORY_MCP_SUMMARIZATION_LLM_MODEL=anthropic/claude-3.5-sonnet
# --- Code Execution Sandbox (optional) ---
# Requires Docker to be available. See docs/sandbox.md for setup instructions.
# MEMORY_MCP_SANDBOX__ENABLED=true
# Use the local Docker socket (default when docker.sock is mounted):
# MEMORY_MCP_SANDBOX__DOCKER_HOST=
# Use a remote Docker daemon instead:
# MEMORY_MCP_SANDBOX__DOCKER_HOST=tcp://remote-docker-host:2375
