# =====================================================
# Memory MCP — 環境変数設定例
# .env にコピーして編集してください。
# ネストされた設定は __ デリミタを使います。
# 例: MEMORY_MCP_QDRANT__URL  (MEMORY_MCP_ + セクション + __ + キー)
# =====================================================

# --- データ・タイムゾーン ---
# MEMORY_MCP_DATA_ROOT=./data
# MEMORY_MCP_DEFAULT_PERSONA=default
# MEMORY_MCP_TIMEZONE=Asia/Tokyo
# MEMORY_MCP_LOG_LEVEL=INFO

# --- サーバー ---
# MEMORY_MCP_SERVER__HOST=0.0.0.0
# MEMORY_MCP_SERVER__PORT=26262

# --- 埋め込みモデル ---
# MEMORY_MCP_EMBEDDING__MODEL=cl-nagoya/ruri-v3-30m   # 日本語特化（デフォルト）
# MEMORY_MCP_EMBEDDING__DEVICE=cpu                    # cpu / cuda / mps
# MEMORY_MCP_EMBEDDING__BATCH_SIZE=32

# --- リランカーモデル ---
# MEMORY_MCP_RERANKER__MODEL=hotchpotch/japanese-reranker-xsmall-v2
# MEMORY_MCP_RERANKER__ENABLED=true

# --- Qdrant（ベクトルストア）---
# ローカル開発: http://localhost:6333
# Docker Compose: http://qdrant:6333 (docker-compose.yml で上書き済み)
# Qdrant Cloud: https://xxxxxxxx.us-east4-0.gcp.cloud.qdrant.io
MEMORY_MCP_QDRANT__URL=http://localhost:6333
# MEMORY_MCP_QDRANT__API_KEY=your-api-key   # Qdrant Cloud の場合のみ

# --- 要約 (オプション) ---
# MEMORY_MCP_SUMMARIZATION__ENABLED=false
# MEMORY_MCP_SUMMARIZATION__USE_LLM=false
# MEMORY_MCP_SUMMARIZATION__LLM_API_URL=https://openrouter.ai/api/v1
# MEMORY_MCP_SUMMARIZATION__LLM_API_KEY=
# MEMORY_MCP_SUMMARIZATION__LLM_MODEL=anthropic/claude-3.5-sonnet

# --- コード実行サンドボックス ---
# Docker が必要です。セットアップは docs/sandbox.md を参照。
# MEMORY_MCP_SANDBOX__ENABLED=false
#
# DinD（推奨 / docker-compose.yml の sandbox-docker サービス使用）:
# MEMORY_MCP_SANDBOX__DOCKER_HOST=tcp://sandbox-docker:2375
#
# リモート Docker ホスト:
# MEMORY_MCP_SANDBOX__DOCKER_HOST=tcp://192.168.1.100:2375
