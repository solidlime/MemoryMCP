# =====================================================
# Nous — 環境変数設定例
# .env にコピーして編集してください。
# ネストされた設定は __ デリミタを使います。
# 例: NOUS_QDRANT__URL  (NOUS_ + セクション + __ + キー)
# =====================================================

# --- データ・タイムゾーン ---
# NOUS_DATA_ROOT=./data
# NOUS_DEFAULT_PERSONA=default
# NOUS_TIMEZONE=Asia/Tokyo
# NOUS_LOG_LEVEL=INFO

# --- サーバー ---
# NOUS_SERVER__HOST=0.0.0.0
# NOUS_SERVER__PORT=26262

# --- 埋め込みモデル ---
# NOUS_EMBEDDING__MODEL=cl-nagoya/ruri-v3-30m   # 日本語特化（デフォルト）
# NOUS_EMBEDDING__DEVICE=cpu                    # cpu / cuda / mps
# NOUS_EMBEDDING__BATCH_SIZE=32

# --- リランカーモデル ---
# NOUS_RERANKER__MODEL=hotchpotch/japanese-reranker-xsmall-v2
# NOUS_RERANKER__ENABLED=true

# --- Qdrant（ベクトルストア）---
# ローカル開発: http://localhost:6333
# Docker Compose: http://qdrant:6333 (docker-compose.yml で上書き済み)
# Qdrant Cloud: https://xxxxxxxx.us-east4-0.gcp.cloud.qdrant.io
NOUS_QDRANT__URL=http://localhost:6333
# NOUS_QDRANT__API_KEY=your-api-key   # Qdrant Cloud の場合のみ

# --- 要約 (オプション) ---

# --- コード実行サンドボックス ---
# Docker ソケット（/var/run/docker.sock）を使ったサイドカーコンテナ方式（デフォルト有効）。
# docker-compose.yml で /var/run/docker.sock がマウントされていれば追加設定不要。
# 無効化したい場合:
# NOUS_SANDBOX__ENABLED=false
#
# リモート Docker ホスト（明示的に指定する場合のみ / 通常不要）:
# NOUS_SANDBOX__DOCKER_HOST=tcp://192.168.1.100:2375

# --- データ永続化パス ---
# DATA_ROOT と NOUS_DATA_ROOT は役割が異なるので注意。
#
#   DATA_ROOT（docker-compose 変数）    = ホスト側のベースパス
#     → 全サービスの volume マウント元として使われる
#     → デフォルト ./data、絶対パス指定も可（例: /volume1/docker/nous）
#
#   NOUS_DATA_ROOT（アプリ内部設定）     = コンテナ側のベースパス
#     → Dockerfile で /opt/nous/data に固定
#     → アプリがデータを読み書きするパス
#
#   ホスト側レイアウト:
#     ${DATA_ROOT}/
#       ├── app/       → /opt/nous/data（Nous アプリデータ）
#       ├── qdrant/    → /qdrant/storage
#       ├── searxng/   → /etc/searxng
#       └── sandbox/   → /home
#
# DATA_ROOT を変更してもコンテナ内部パスは変わらないので、
# アプリの設定やコードを一切触らずにデータ保存先だけ差し替えられる。
#
# デフォルト（開発用）:
# DATA_ROOT=./data
#
# NAS / 本番用の例:
DATA_ROOT=/volume1/docker/nous
